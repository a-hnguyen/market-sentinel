# Copy to .env (which is git-ignored) and fill in your Alpaca keys.
# Free/paper keys work — v1 uses the IEX 1-min bar stream, no paid data needed.
# Get keys at https://app.alpaca.markets (API Keys).
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# ntfy push alerts to phone + desktop (optional). Pick a hard-to-guess topic and
# subscribe every device (iOS app, Windows web app) to that exact string.
# Leave NTFY_TOPIC unset to disable push (console-only).
NTFY_TOPIC=market-sentinel-changeme-xxxxxxxx
# NTFY_SERVER=https://ntfy.sh   # override for a self-hosted server
# NTFY_TOKEN=                    # set for a private/reserved topic
