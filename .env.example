# Copy to .env (which is git-ignored) and fill in your Alpaca keys.
# Free/paper keys work — v1 uses the IEX 1-min bar stream, no paid data needed.
# Get keys at https://app.alpaca.markets (API Keys).
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here

# Private Discord control + alert channel. IDs are numeric Discord snowflakes;
# enable Developer Mode in Discord to copy them. Separate multiple authorized
# people with commas. The bot runs over an outbound Gateway connection.
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_GUILD_ID=your_server_id
DISCORD_CHANNEL_ID=your_private_channel_id
DISCORD_ALLOWED_USER_IDS=your_user_id,second_user_id
