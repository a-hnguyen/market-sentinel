# Copy to terraform.tfvars (git-ignored) and adjust. Defaults in variables.tf are
# sensible for a small single-box deploy, so this can stay nearly empty.

# region        = "us-east-1"
# instance_type = "t3.micro"          # tested x86 default; verify account pricing

# Get infra-health emails (engine down / alarm). Not the trading alert channel.
# ops_email = "you@example.com"

# Pin the AMI instead of auto-resolving latest Amazon Linux 2023:
# ami_id = "ami-0abcdef1234567890"

# tags = { Owner = "anna", Env = "prod" }
